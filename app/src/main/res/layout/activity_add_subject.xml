<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thêm môn học mới" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="20dp"/>

        <EditText android:id="@+id/editName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Tên môn học" android:inputType="textCapWords"/>
        <EditText android:id="@+id/editRoom" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Phòng học" android:layout_marginTop="10dp"/>
        <EditText android:id="@+id/editTime" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Thời gian (VD: Thứ 2, Tiết 1-3)" android:layout_marginTop="10dp"/>
        <EditText android:id="@+id/editTeacher" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Tên giảng viên" android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lưu lịch học"
            android:layout_marginTop="30dp"/>
    </LinearLayout>
</ScrollView>