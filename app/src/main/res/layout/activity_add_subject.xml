<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtAddTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thêm môn học mới"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/editName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên môn học (VD: Trí tuệ nhân tạo)"
            android:inputType="textCapWords"/>

        <EditText
            android:id="@+id/editClassCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mã lớp (VD: 24DHTT03)"
            android:layout_marginTop="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Spinner
                android:id="@+id/spinnerDay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <EditText
                android:id="@+id/editLesson"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Tiết (VD: 1-4)"/>
        </LinearLayout>

        <EditText
            android:id="@+id/editTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Giờ học (VD: 07:00 - 10:35)"
            android:layout_marginTop="10dp"/>

        <EditText
            android:id="@+id/editRoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Phòng học (VD: G502)"
            android:layout_marginTop="10dp"/>

        <EditText
            android:id="@+id/editTeacher"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên giảng viên"
            android:layout_marginTop="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loại lịch học:"
            android:layout_marginTop="15dp"
            android:textSize="14sp"/>

        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lưu lịch học"
            android:backgroundTint="#1A237E"
            android:textColor="@android:color/white"
            android:layout_marginTop="30dp"/>

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xóa môn học"
            android:backgroundTint="#D32F2F"
            android:textColor="@android:color/white"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>
    </LinearLayout>
</ScrollView>