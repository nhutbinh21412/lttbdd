<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F2F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TÌM KIẾM MÔN HỌC"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chọn học kỳ:"/>
    <Spinner
        android:id="@+id/spinnerSemester"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/edtSearchSubject"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@android:drawable/editbox_background"
        android:hint="Nhập thông tin môn học"
        android:paddingLeft="10dp" />

    <Button
        android:id="@+id/btnSearchAction"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="TÌM KIẾM"
        android:layout_marginTop="16dp"
        android:backgroundTint="#1A73E8" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycleViewSearchResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp" />

</LinearLayout>